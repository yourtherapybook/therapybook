# Core app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/therapybook?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Payments
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Transactional email
RESEND_API_KEY="re_replace_me"
ADMIN_ALERT_EMAIL="admin@example.com"
SUPPORT_EMAIL="support@example.com"
FROM_EMAIL="TherapyBook <noreply@yourdomain.com>"

# Background jobs / scheduled reminders
KV_URL="redis://localhost:6379"
CRON_SECRET="replace-with-a-random-cron-secret"

# Cloudflare R2 uploads
R2_ACCOUNT_ID="replace-with-your-r2-account-id"
R2_ACCESS_KEY_ID="replace-with-your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-your-r2-secret-access-key"
R2_BUCKET_NAME="therapybook-documents"
NEXT_PUBLIC_R2_DEV_URL="https://pub-your-bucket.example.r2.dev"

# Video sessions
NEXT_PUBLIC_JITSI_DOMAIN="meet.jit.si"
